<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IBM i PTF Currency Report</title>
  <style>
    body { font-family: "Segoe UI", Arial, sans-serif; margin: 24px; color: #1f2937; }
    h1, h2 { margin-bottom: 8px; }
    .meta { color: #4b5563; margin-bottom: 20px; }
    .ok { color: #166534; font-weight: 600; }
    .warn { color: #92400e; font-weight: 600; }
    table { border-collapse: collapse; width: 100%; margin-top: 10px; }
    th, td { border: 1px solid #d1d5db; padding: 8px; text-align: left; }
    th { background: #f3f4f6; }
    .panel { border: 1px solid #d1d5db; border-radius: 8px; padding: 12px; margin: 12px 0; }
  </style>
</head>
<body>
  <h1>IBM i PTF Currency Report</h1>
  <p class="meta">Host: {{ inventory_hostname }} | Generated by Ansible</p>

  <div class="panel">
    <h2>Compliance Summary</h2>
    {% if (critical_ptfs | length) == 0 %}
    <p>Compliance: <strong>N/A</strong> (no critical PTF baseline configured)</p>
    <p class="warn">Set critical_ptfs in the playbook or via ansible extra vars to compute compliance.</p>
    {% else %}
    <p>Compliance: <strong>{{ compliance_percentage }}%</strong></p>
    {% if (missing_critical_ptfs | length) == 0 %}
    <p class="ok">No missing critical PTFs detected.</p>
    {% else %}
    <p class="warn">Missing critical PTFs detected.</p>
    {% endif %}
    {% endif %}
  </div>

  <div class="panel">
    <h2>Missing Critical PTFs</h2>
    {% if (missing_critical_ptfs | length) == 0 %}
      <p>None</p>
    {% else %}
      <ul>
      {% for ptf in missing_critical_ptfs %}
        <li>{{ ptf }}</li>
      {% endfor %}
      </ul>
    {% endif %}
  </div>

  <div class="panel">
    <h2>PTF Group Check (raw)</h2>
    <pre>{{ ptf_group_result | to_nice_json }}</pre>
  </div>

  <div class="panel">
    <h2>System Status (raw)</h2>
    <pre>{{ system_status_result | to_nice_json }}</pre>
  </div>

  <div class="panel">
    <h2>Installed PTF Rows (sample)</h2>
    <p>Total rows captured: {{ ptf_rows | length }}</p>
    <pre>{{ (ptf_rows[:10] if (ptf_rows | length) > 0 else []) | to_nice_json }}</pre>
  </div>
</body>
</html>
